<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>マスター詳細</title>
  <link rel="stylesheet" href="/public/styles.css">

  <style>
    /* ===== 高密度・業務用 ===== */

    .detail-wrap {
    max-width: 900px;
    margin: 0 auto;
    padding: 10px;
    }

    .card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 4px;     /* 丸み最小 */
    box-shadow: none;       /* 影なし */
    }

    /* テーブル全体 */
    .table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;        /* 少し小さく */
    }

    /* 行 */
    .table th,
    .table td {
    padding: 4px 8px;       /* ← ここが一番効く */
    line-height: 1.4;       /* 文字の約2〜3倍 */
    border-bottom: 1px solid #e5e7eb;
    vertical-align: top;
    }

    /* キー側 */
    .table th {
    width: 180px;
    background: #f9fafb;
    font-weight: 600;
    }

    /* 値側 */
    .value {
    white-space: pre-wrap;
    word-break: break-word;
    }

    /* バッジも小さく */
    .badge {
    padding: 1px 6px;
    font-size: 11px;
    line-height: 1.2;
    }

    /* 上部ヘッダも詰める */
    .detail-title {
    font-size: 18px;
    margin-bottom: 4px;
    }

    .detail-sub {
    font-size: 12px;
    margin-bottom: 8px;
    }

  </style>
</head>

<body>
  <div class="detail-wrap">
    <div class="detail-head">
      <div>
        <h1 class="detail-title">マスター詳細</h1>
        <p class="detail-sub">
          <span class="pill mono"><%= table %></span>
          <span class="pill mono">id=<%= row.id %></span>
        </p>
      </div>

      <div class="detail-actions">
        <a class="btn" href="/masters">← 一覧に戻る</a>
      </div>
    </div>

    <%
// ===== 日本語ラベル =====
const jpMap = {
  // ===== 既存 =====
  id: "ID",
  is_active: "有効",
  PN: "型番（旧）",
  PN2: "型番",
  type: "タイプ",
  supplier: "仕入先",
  inch: "インチ数",
  mount_type: "取付方式",
  orientation: "設置向き",
  panel_brand: "パネルメーカー",
  display_area: "表示領域",
  resolution: "解像度",
  brightness: "輝度",
  contrast_ratio: "コントラスト比",
  response_time: "応答速度",
  viewing_angle: "視野角",
  voltage: "電圧",
  tempurature_operating: "動作温度",
  humidity_operationg: "動作湿度",
  warranty_term: "保証期間",
  remote_controller_attachTF: "リモコン付属",
  key_attachTF: "鍵付属",
  power_cable_attachTF: "電源ケーブル付属",
  FC: "ファンクーリング",
  brightness_sensor: "輝度センサー",
  IP: "防塵防水等級",
  color: "筐体色",

  // ===== ここから追加 =====
  delivery_lead_time_days: "納品スパン（日数）",
  supplier_id: "サプライヤーID",

  bezel_width: "ベゼル幅",
  color_body: "筐体色",

  touch: "タッチ対応",
  touch_type: "タッチ方式",

  OS: "OS",
  CPU: "CPU",
  gms_certified: "GMS認証",
  RAM: "RAM",
  ROM: "ROM",

  LANconnection_TF: "LAN接続可否",
  Wi_Ficonnection_TF: "Wi-Fi接続可否",
  "4G": "4G対応",

  HDMI_input_TF: "HDMI入力有無",
  HDMI_input_amount: "HDMI入力数",

  USB_input_TF: "USB入力有無",
  USB_input_standard: "USB規格",
  USB_input_amount: "USB入力数",

  LAN_input_TF: "LAN端子有無",
  LAN_input_amount: "LAN端子数",

  RS232_input_TF: "RS232入力有無",
  RS232_input_amount: "RS232入力数",
  RS232_output_TF: "RS232出力有無",
  RS232_output_amount: "RS232出力数",

  DVI_input_TF: "DVI入力有無",
  DVI_input_amount: "DVI入力数",

  VGA_input_TF: "VGA入力有無",
  VGA_input_amount: "VGA入力数",

  DP_input_TF: "DP入力有無",
  DP_input_amount: "DP入力数",

  IR_input_TF: "IR入力有無",
  IR_input_amount: "IR入力数",

  sound_output: "スピーカー有無",
  sound_power: "スピーカー出力",

  pixel_pitch: "ピクセルピッチ",
  depth_color: "色深度",
  aspect_ratio: "アスペクト比",

  frequency: "周波数",
  power_max_consumption: "最大消費電力",
  power_standby: "待機電力",

  weight: "重量",

  created_at: "作成日",
  updated_at: "更新日"
};


function isValid(v) {
  return v !== null && v !== undefined && v !== '' && v !== 'NULL';
}

function renderValue(key, value) {
  // TF系（remote_controller_attachTF など）
  if (/_TF$/.test(key)) {
    if (value === 1 || value === "1" || value === true) return "あり";
    if (value === 0 || value === "0" || value === false) return "なし";
    return "";
  }

  // is_active はバッジ表示側で処理するのでここでは素通し
  return value;
}


// 重要項目（必要に応じて追加/削除OK）
const IMPORTANT_KEYS = ["id","PN","PN2","is_active","inch","type","suplier","supplier"];

// row から表示対象だけ抽出（NULL系は落とす）
const entries = Object.entries(row || {}).filter(([k, v]) => isValid(v));

// key → label
const labelOf = (key) => jpMap[key] || `${key}（未翻訳）`;

// 重要 / その他 に分ける
const importantEntries = entries.filter(([k]) => IMPORTANT_KEYS.includes(k));
const otherEntries = entries.filter(([k]) => !IMPORTANT_KEYS.includes(k));
%>

<div class="card" style="margin-bottom:16px;">
  <table class="table">
    <tbody>
      <% importantEntries.forEach(([key, value]) => { %>
        <tr>
          <th><%= labelOf(key) %></th>
          <td class="value">
            <% if (key === "is_active") { %>
              <span class="badge <%= Number(value) === 1 ? 'on' : 'off' %>">
                <%= Number(value) === 1 ? "ON" : "OFF" %>
              </span>
            <% } else { %>
              <%= value %>
            <% } %>
          </td>
        </tr>
      <% }); %>

      <% if (importantEntries.length === 0) { %>
        <tr>
          <th>表示</th>
          <td class="value">重要項目が見つかりませんでした。</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<details class="card" <%= otherEntries.length ? "" : "open" %>>
  <summary style="cursor:pointer; font-weight:600; padding:12px;">
    その他の詳細スペック
  </summary>

  <table class="table">
    <tbody>
      <% otherEntries.forEach(([key, value]) => { %>
        <tr>
          <th><%= labelOf(key) %></th>
          <td class="value"><%= renderValue(key, value) %></td>
        </tr>
      <% }); %>

      <% if (otherEntries.length === 0) { %>
        <tr>
          <th>詳細</th>
          <td class="value">追加のスペックはありません。</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</details>
</body>
</html>
